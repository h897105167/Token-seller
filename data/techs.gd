class_name TechDB
extends RefCounted
## 所有科技的静态数据库

class TechData:
	extends RefCounted
	## 科技数据定义
	var id: String
	var name: String
	var category: String    # "input", "item", "universal"
	var target_item_id: String  # for item techs, the item this tech affects; "" for input/universal
	var effect_type: String
	var price: float
	var unlock_condition: Dictionary
	var description: String
	var prereq_tech_id: String
	var secondary_effect: Dictionary  # for input techs, stores input_base_linear part
	var icon_path: String
	var tier: int

	func _init(p_id: String = "", p_name: String = "", p_category: String = "", p_target_item_id: String = "", p_effect_type: String = "", p_price: float = 0.0, p_unlock_condition: Dictionary = {}, p_description: String = "", p_prereq_tech_id: String = "", p_secondary_effect: Dictionary = {}, p_icon_path: String = "", p_tier: int = 1) -> void:
		id = p_id
		name = p_name
		category = p_category
		target_item_id = p_target_item_id
		effect_type = p_effect_type
		price = p_price
		unlock_condition = p_unlock_condition
		description = p_description
		prereq_tech_id = p_prereq_tech_id
		secondary_effect = p_secondary_effect
		icon_path = p_icon_path
		tier = p_tier


# 物品科技解锁所需的物品数量: t1=1, t2=50, t3=100, ... t15=700
const _ITEM_TECH_UNLOCKS: Array = [1, 50, 100, 150, 200, 250, 300, 350, 400, 450, 500, 550, 600, 650, 700]

# ===== 静态缓存（避免每次调用都重建 321 个对象）=====
static var _cache_all: Array = []
static var _cache_by_id: Dictionary = {}
static var _cache_input: Array = []
static var _cache_universal: Array = []
static var _cache_item: Dictionary = {}  # item_id -> Array


static func _ensure_cache() -> void:
	if _cache_all.size() > 0:
		return
	var techs: Array = []
	_add_input_techs(techs)
	_add_universal_techs(techs)
	_add_all_item_techs(techs)
	_cache_all = techs
	for tech in techs:
		_cache_by_id[tech.id] = tech
		if tech.category == "input":
			_cache_input.append(tech)
		elif tech.category == "universal":
			_cache_universal.append(tech)
		elif tech.category == "item":
			if not _cache_item.has(tech.target_item_id):
				_cache_item[tech.target_item_id] = []
			_cache_item[tech.target_item_id].append(tech)


static func _make_item_techs(item_id: String, tech_data: Array) -> Array:
	var techs: Array = []
	var prev_id: String = ""
	var icon_path: String = "res://assets/icons/items/%s.jpg" % item_id
	for i in range(15):
		var t_num: int = i + 1
		var tech_id: String = "%s_t%d" % [item_id, t_num]
		var effect_type: String
		if t_num == 1:
			effect_type = "item_other_linear"
		elif t_num == 2:
			effect_type = "item_self_to_others_linear"
		else:
			effect_type = "item_double"
		var unlock: Dictionary = {"type": "item_count", "item_id": item_id, "value": _ITEM_TECH_UNLOCKS[i]}
		var entry: Array = tech_data[i]
		var tier: int = get_tier_for_tech_num(t_num)
		techs.append(TechData.new(tech_id, entry[0], "item", item_id, effect_type, float(entry[1]), unlock, entry[2], prev_id, {}, icon_path, tier))
		prev_id = tech_id
	return techs


## 根据科技序号计算所属层级 tier
## t1-3=tier1, t4-6=tier2, t7-9=tier3, t10-12=tier4, t13-15=tier5
static func get_tier_for_tech_num(t_num: int) -> int:
	return (t_num - 1) / 3 + 1


static func get_all_techs() -> Array:
	_ensure_cache()
	return _cache_all


